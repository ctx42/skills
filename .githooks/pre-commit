#!/usr/bin/env bash
# Keeps plugin/marketplace manifest versions in lockstep with VER.
#
# A version bump writes VER and commits it. This hook fires on that commit: if
# VER is part of the commit, it derives the manifest versions from VER
# (dev/version.sh sync) and stages them, so the bump commit — and the tag placed on
# it — carry matching versions. However VER is bumped (release tool or by hand),
# it is covered. Commits that leave VER untouched make the hook no-op.
#
# Fail closed: any error (unwritable manifest, bad input) exits non-zero and
# aborts the commit, so a release can never proceed with drifted versions.
#
# Enable per clone with: ./dev/version.sh install-hooks
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# Only act when VER is part of this commit.
if ! git diff --cached --name-only | grep -qx 'VER'; then
    exit 0
fi

"$ROOT/dev/version.sh" sync

# Stage the derived manifests so they ride in this commit and its tag.
while IFS= read -r manifest; do
    git add -- "$manifest"
done < <("$ROOT/dev/version.sh" manifests)
